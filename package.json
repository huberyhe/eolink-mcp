{
  "name": "@huberyhe/eolink-mcp",
  "version": "1.0.0",
  "description": "MCP server for Eolink Apikit Open API — query API docs from any Eolink instance (SaaS or private)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "eolink-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && chmod +x dist/index.js"
  },
  "keywords": [
    "mcp",
    "eolink",
    "apikit",
    "api-docs",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huberyhe/eolink-mcp.git"
  },
  "homepage": "https://github.com/huberyhe/eolink-mcp#readme",
  "bugs": {
    "url": "https://github.com/huberyhe/eolink-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
